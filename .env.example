# AI Hair Salon Agent local configuration.
# Copy to .env for local development. Do not commit .env.

# Database
DATABASE_URL=sqlite:///./data/salon.db

# OpenAI-compatible chat model used for classification and answer generation.
# Qwen DashScope compatible mode is one supported option.
# Fill LLM_API_KEY locally before real chat/provider calls. Do not commit it.
MODEL_PROVIDER=qwen
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Optional embedding config for code paths that need an OpenAI-compatible embedding provider.
# Fill EMBEDDING_API_KEY locally before real embedding/provider calls. Do not commit it.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# MCP Knowledge Service integration.
# Default is booking-only local startup.
# Set true only after RAG_MCP_SERVER_PYTHON and RAG_MCP_SERVER_CWD point to a valid local MCP Knowledge Service checkout.
# 只有在 RAG_MCP_SERVER_PYTHON 和 RAG_MCP_SERVER_CWD 已指向有效本地 MCP Knowledge Service 后，才设为 true。
RAG_MCP_ENABLED=false
RAG_MCP_SERVER_PYTHON=<PATH_TO_MCP_KNOWLEDGE_SERVICE>/.venv/bin/python
RAG_MCP_SERVER_MODULE=src.mcp_server.server
RAG_MCP_SERVER_CWD=<PATH_TO_MCP_KNOWLEDGE_SERVICE>
RAG_MCP_COLLECTION=salon_knowledge
RAG_MCP_QUERY_TOP_K=4

# CORS.
# Empty by default: same-origin usage only, no cross-origin middleware.
# Use comma-separated explicit origins only when a separate frontend origin is needed. Do not use wildcard.
CORS_ALLOWED_ORIGINS=

# Optional Weather Context Tool.
# Disabled by default. It is only used after a conversational booking succeeds.
WEATHER_ENABLED=false
OPENWEATHER_API_KEY=
WEATHER_LOCATION=
WEATHER_TIMEOUT_SECONDS=3
