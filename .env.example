# AI Hair Salon Agent 本地配置。
# 本地开发时复制为 .env；不要提交 .env。

# 为兼容现有本地运行方式，默认允许调用真实外部服务。
# 测试、CI 和隔离验证会显式覆盖为 deny。
EXTERNAL_CALL_POLICY=allow

# 数据库
DATABASE_URL=sqlite:///./data/salon.db

# 用于分类和回答生成的 OpenAI-compatible 对话模型。
# 支持使用 Qwen DashScope 兼容模式。
# 调用真实对话模型前在本地填写 LLM_API_KEY；不要提交该值。
MODEL_PROVIDER=qwen
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# 需要 OpenAI-compatible Embedding 外部服务时使用的可选配置。
# 调用真实 Embedding 服务前在本地填写 EMBEDDING_API_KEY；不要提交该值。
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# MCP Knowledge Service 集成。
# 默认仅启动本地预约功能。
# 只有在 RAG_MCP_SERVER_PYTHON 和 RAG_MCP_SERVER_CWD 指向有效的本地 MCP Knowledge Service 后，才设为 true。
RAG_MCP_ENABLED=false
RAG_MCP_SERVER_PYTHON=<PATH_TO_MCP_KNOWLEDGE_SERVICE>/.venv/bin/python
RAG_MCP_SERVER_MODULE=src.mcp_server.server
RAG_MCP_SERVER_CWD=<PATH_TO_MCP_KNOWLEDGE_SERVICE>
RAG_MCP_COLLECTION=salon_knowledge
RAG_MCP_QUERY_TOP_K=4

# CORS。
# 默认留空：仅支持同源使用，不启用跨域中间件。
# 只有独立前端域名确有需要时才填写逗号分隔的明确来源；不要使用通配符。
CORS_ALLOWED_ORIGINS=

# 可选账户认证。禁用时游客预约仍可使用。
# 为 AUTH_JWT_SECRET 生成至少 32 个随机字节的私有值。
AUTH_ENABLED=true
AUTH_JWT_SECRET=
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=30
AUTH_JWT_ISSUER=ai-hair-salon-agent
AUTH_JWT_AUDIENCE=ai-hair-salon-web
AUTH_COOKIE_NAME=salon_access_token
AUTH_REFRESH_COOKIE_NAME=salon_refresh_token
AUTH_REFRESH_COOKIE_PATH=/api/auth
AUTH_CSRF_COOKIE_NAME=salon_csrf_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_REFRESH_REUSE_GRACE_SECONDS=3
AUTH_AUTH_SESSION_RETENTION_DAYS=30

# 登录和注册使用当前应用进程内的有界滑动窗口限流。
# 仅识别直连 request.client.host，不信任客户端提交的代理转发头。
AUTH_RATE_LIMIT_ENABLED=true
AUTH_LOGIN_CLIENT_LIMIT=10
AUTH_LOGIN_CLIENT_WINDOW_SECONDS=60
AUTH_LOGIN_CLIENT_ACCOUNT_LIMIT=5
AUTH_LOGIN_CLIENT_ACCOUNT_WINDOW_SECONDS=300
AUTH_REGISTER_CLIENT_LIMIT=3
AUTH_REGISTER_CLIENT_WINDOW_SECONDS=3600
AUTH_REFRESH_CLIENT_LIMIT=30
AUTH_REFRESH_CLIENT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_BUCKETS=10000
AUTH_RATE_LIMIT_CLEANUP_INTERVAL_SECONDS=60

# 可选天气上下文工具。
# Open-Meteo 不需要 API Key，只在聊天预约保存成功后运行。
WEATHER_ENABLED=true
WEATHER_PROVIDER=open_meteo
WEATHER_LOCATION_NAME=上海
WEATHER_LATITUDE=31.2304
WEATHER_LONGITUDE=121.4737
WEATHER_TIMEZONE=Asia/Shanghai
WEATHER_TIMEOUT_SECONDS=3
WEATHER_FORECAST_DAYS=16
